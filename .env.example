## Margin Insights – example environment

# App base URL (used in links, emails later if needed)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# NextAuth base URL – REQUIRED for OAuth (Google)
# Local: http://localhost:3000 (or :3001 if you use a different port)
# Prod:  https://margin-insights.vercel.app
# Note: next.config.js auto-forces localhost in dev if this points to prod
NEXTAUTH_URL=http://localhost:3000

# Authentication secret for signing session cookies
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_AUTH_SECRET=replace-with-random-hex

# Google OAuth – SSO is the only auth method
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Admin by email – comma-separated list of emails that get admin access
# Example: ADMIN_EMAILS="admin@example.com,other@example.com"
ADMIN_EMAILS=

# Database configuration
# IMPORTANT for Vercel/serverless: Use the POOLED connection string.
# - Neon: Use the connection string with -pooler in the hostname (e.g. ep-xxx-pooler.us-east-1.aws.neon.tech)
# - Vercel Postgres: Use POSTGRES_URL from the integration (already pooled)
# - Add ?connect_timeout=15 for reliability
DATABASE_URL=postgresql://USERNAME:PASSWORD@HOST/DATABASE?sslmode=require

# For migrations only (unpooled/direct connection)
DATABASE_URL_UNPOOLED=postgresql://USERNAME:PASSWORD@HOST_UNPOOLED/DATABASE?sslmode=require

# Parameters for constructing your own connection string
PGHOST=your-pooled-hostname
PGHOST_UNPOOLED=your-unpooled-hostname
PGUSER=your-db-username
PGDATABASE=your-db-name
PGPASSWORD=your-db-password

# Parameters for Vercel Postgres Templates
POSTGRES_URL=postgresql://USERNAME:PASSWORD@HOST/DATABASE?sslmode=require
POSTGRES_URL_NON_POOLING=postgresql://USERNAME:PASSWORD@HOST_UNPOOLED/DATABASE?sslmode=require
POSTGRES_USER=your-db-username
POSTGRES_HOST=your-pooled-hostname
POSTGRES_PASSWORD=your-db-password
POSTGRES_DATABASE=your-db-name
POSTGRES_URL_NO_SSL=postgresql://USERNAME:PASSWORD@HOST/DATABASE
POSTGRES_PRISMA_URL=postgresql://USERNAME:PASSWORD@HOST/DATABASE?connect_timeout=15&sslmode=require

